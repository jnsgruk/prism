  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                id,\n                source_name,\n                started_at,\n                completed_at,\n                status AS \"status!\",\n                items_collected,\n                error_message,\n                handler_name AS \"handler_name!\",\n                handler_method AS \"handler_method!\",\n                pipeline_id\n            FROM activity.ingestion_runs\n            WHERE handler_name = $1 AND status = 'running'\n            ORDER BY started_at DESC\n            LIMIT 1\n            ",
