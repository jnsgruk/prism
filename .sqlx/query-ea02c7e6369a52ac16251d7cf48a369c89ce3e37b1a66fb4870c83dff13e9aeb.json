{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT p.id, p.name, p.email, p.level\n            FROM org.people p\n            JOIN org.team_memberships tm ON tm.person_id = p.id\n            WHERE tm.team_id = $1\n              AND (tm.end_date IS NULL OR tm.end_date > CURRENT_DATE)\n            ORDER BY p.name\n            ",
