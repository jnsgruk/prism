  "query": "\n            SELECT id, source_name, started_at, completed_at, status,\n                   items_collected, error_message\n            FROM activity.ingestion_runs\n            WHERE ($1::text IS NULL OR source_name = $1)\n            ORDER BY started_at DESC\n            LIMIT 50\n            ",
