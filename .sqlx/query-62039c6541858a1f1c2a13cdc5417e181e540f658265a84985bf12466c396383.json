{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT s.id as session_id, s.expires_at, u.id as user_id,\n                   u.username, u.display_name, u.role, u.is_active\n            FROM auth.sessions s\n            JOIN auth.users u ON s.user_id = u.id\n            WHERE s.token_hash = $1\n            ",
