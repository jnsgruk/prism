{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT p.id, p.name, p.email, p.level, p.active,\n                   t.name AS \"team_name?\"\n            FROM org.people p\n            LEFT JOIN org.team_memberships tm ON tm.person_id = p.id\n                AND (tm.end_date IS NULL OR tm.end_date > CURRENT_DATE)\n            LEFT JOIN org.teams t ON t.id = tm.team_id\n            ORDER BY p.name\n            ",
